{
  "name": "labos",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "protocol:build": "pnpm -C packages/protocol build",
    "protocol:gen:swift": "pnpm -C packages/protocol build && pnpm -C tools/codegen-swift gen",
    "codex-spec:refresh": "pnpm -C packages/codex-spec refresh",
    "codex-spec:check": "pnpm -C packages/codex-spec check"
  }
}
