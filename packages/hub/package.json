{
  "name": "@labos/hub",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "labos-hub": "dist/cli.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "migrations/"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test tests/*.test.mjs",
    "codex:schema:check": "pnpm -C ../codex-spec check"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@labos/protocol": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.5.0",
    "pdf-parse": "^2.4.5",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "ajv": "^8.17.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
