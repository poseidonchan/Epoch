{
  "name": "@epoch/protocol",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && node scripts/write-schema.mjs",
